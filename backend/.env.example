# Core
PORT=3001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Frontend origins allowed by CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# Socket auth token (required in production)
SOCKET_AUTH_TOKEN=change_me_super_secret

# Socket event rate limiting
SOCKET_RATE_LIMIT_WINDOW_MS=10000
SOCKET_RATE_LIMIT_MAX=30

# Link preview hardening
LINK_PREVIEW_TIMEOUT_MS=5000
LINK_PREVIEW_MAX_BYTES=1048576
LINK_PREVIEW_BLOCKED_HOSTS=localhost,metadata.google.internal

# WooCommerce (optional)
WC_BASE_URL=
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
WC_PER_PAGE=100
WC_MAX_PAGES=10
WC_INCLUDE_OUT_OF_STOCK=true

# WhatsApp transport mode
# webjs (current QR session) or cloud (planned provider; falls back to webjs for now)
WA_TRANSPORT=webjs

# Meta Cloud API placeholders (used when cloud transport is enabled)
META_APP_ID=
META_APP_SECRET=
META_SYSTEM_USER_TOKEN=
META_WABA_ID=
META_WABA_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=
