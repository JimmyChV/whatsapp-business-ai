# Production template (no real secrets)
PORT=3001
NODE_ENV=production

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# SaaS foundation (phase 1)
SAAS_ENABLED=true
SAAS_AUTH_ENABLED=true
SAAS_AUTH_SECRET=replace_with_64_char_random_secret
SAAS_TOKEN_TTL_SEC=28800
SAAS_REFRESH_TOKEN_TTL_SEC=2592000
SAAS_MAX_REFRESH_SESSIONS_PER_USER=8
SAAS_REVOKED_TOKEN_STORE_LIMIT=5000
SAAS_AUDIT_FILE_LIMIT=5000
# JSON array users. Single-tenant legacy and multi-tenant memberships are supported:
# [{"id":"owner_1","email":"owner@empresa.com","tenantId":"tenant_acme","role":"owner","passwordHash":"sha256_hex"}]
# [{"id":"owner_1","email":"owner@empresa.com","role":"owner","memberships":[{"tenantId":"tenant_acme","role":"owner"},{"tenantId":"tenant_beta","role":"admin"}],"passwordHash":"sha256_hex"}]
SAAS_USERS_JSON=[]
SAAS_TENANTS_JSON=[]
# JSON array: [{"tenantId":"tenant_acme","settings":{"catalogMode":"woo_only","enabledModules":{"aiPro":true}}}]
SAAS_TENANT_SETTINGS_JSON=[]
# JSON array with superadmin identifiers (email or user id)
SAAS_SUPERADMINS_JSON=[]
# Optional override for plan limits/features (JSON object by plan id)
SAAS_PLAN_LIMITS_JSON={}
# Default catalog mode per tenant if no explicit setting: hybrid | woo_only | local_only
SAAS_DEFAULT_CATALOG_MODE=hybrid
SAAS_SOCKET_AUTH_REQUIRED=true
# Persistence driver for tenant data: file (default) | postgres
SAAS_STORAGE_DRIVER=file
# Optional custom directory for file driver (defaults to backend/data/tenants)
SAAS_TENANT_DATA_DIR=
# Persist incoming/sent message history by tenant (true|false)
HISTORY_PERSISTENCE_ENABLED=true
# Max chats scanned when falling back to persisted history
HISTORY_FALLBACK_MAX_CHATS=3000
# Postgres connection (used when SAAS_STORAGE_DRIVER=postgres)
DATABASE_URL=
# Optional split Postgres vars
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=
PGSSL=false

# Frontend URL(s) allowed to call backend (comma-separated)
ALLOWED_ORIGINS=https://app.tu-dominio.com
CORS_ALLOW_EMPTY_IN_PROD=false

# Security hardening
SECURITY_HEADERS_ENABLED=true
TRUST_PROXY=true

# Operations / observability
OPS_API_TOKEN=replace_with_64_char_random_secret
OPS_READY_REQUIRE_WA=true
OPS_MAX_LATENCY_SAMPLES=8000
SHUTDOWN_FORCE_TIMEOUT_MS=15000
OPS_ALERT_WEBHOOK_URL=
OPS_PILOT_SAMPLES=20
OPS_PILOT_INTERVAL_MS=30000
OPS_PILOT_TIMEOUT_MS=7000
OPS_PILOT_MAX_P95_MS=1200
OPS_PILOT_MAX_ERROR_RATE=0.01
OPS_PILOT_MIN_READY_RATIO=0.995
PHASE5_CLOSEOUT_REQUESTS=120
PHASE5_CLOSEOUT_CONCURRENCY=8
PHASE5_CLOSEOUT_SAMPLES=10
PHASE5_CLOSEOUT_INTERVAL_MS=3000
PHASE5_CLOSEOUT_TIMEOUT_MS=7000
PHASE5_CLOSEOUT_OUT_DIR=

# Socket auth (required in production)
SOCKET_AUTH_TOKEN=replace_with_64_char_random_secret
SOCKET_AUTH_REQUIRED=true

# HTTP API rate limiting
HTTP_RATE_LIMIT_ENABLED=true
HTTP_RATE_LIMIT_WINDOW_MS=10000
HTTP_RATE_LIMIT_MAX=120

# Socket event rate limiting
SOCKET_RATE_LIMIT_WINDOW_MS=10000
SOCKET_RATE_LIMIT_MAX=30

# Debug toggles (keep off in production)
ORDER_DEBUG=false
ORDER_DEBUG_MISSING=false
ORDER_DEBUG_VERBOSE=false
CATALOG_DEBUG=false
CATALOG_DEBUG_MAX_ITEMS=120

# Link preview hardening
LINK_PREVIEW_TIMEOUT_MS=5000
LINK_PREVIEW_MAX_BYTES=1048576
LINK_PREVIEW_BLOCKED_HOSTS=localhost,metadata.google.internal,169.254.169.254

# WooCommerce (optional)
WC_BASE_URL=
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
WC_PER_PAGE=100
WC_MAX_PAGES=10
WC_INCLUDE_OUT_OF_STOCK=true

# WhatsApp transport mode
# dual (recommended): user selects mode from frontend
# webjs: force QR/webjs
# cloud: force Cloud API
WA_TRANSPORT=dual

# Meta Cloud API (required for cloud mode)
META_APP_ID=
META_APP_SECRET=
META_SYSTEM_USER_TOKEN=
META_WABA_ID=
META_WABA_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=
META_ENFORCE_SIGNATURE=true
META_GRAPH_VERSION=v22.0
META_DISPLAY_PHONE_NUMBER=


